# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_BROKER_HOST=kafka
KAFKA_BROKER_PORT=9092
KAFKA_CLIENT_ID=stock-market-mlops
KAFKA_RAW_TOPIC=stock.raw
KAFKA_FEATURES_TOPIC=stock.features
KAFKA_FEATURES_GROUP_ID=stock-feature-engineering

# Data Source Configuration
TWELVEDATA_API_KEY=your_api_key_here
TWELVEDATA_WS_URL=wss://ws.twelvedata.com/v1/quotes/price
TWELVEDATA_SYMBOLS=AAPL,MSFT,TSLA

# MLflow Configuration
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=stock-market-prediction
MLFLOW_ARTIFACT_STORE=/mlflow/artifacts

# DVC Configuration
DVC_REMOTE_STORAGE=/dvc_storage
DVC_DATA_DIR=./data

# Model Configuration
MODEL_CHECKPOINT_DIR=/app/models
LOG_DIR=/app/logs

# Feature Engineering
FEATURE_WINDOW_SIZE=30
FEATURE_STEP_SIZE=1

# Prediction Configuration
PREDICTION_BATCH_SIZE=32
PREDICTION_THRESHOLD=0.5

# Drift Monitoring
DRIFT_THRESHOLD=0.05
DRIFT_WINDOW_SIZE=500
DRIFT_CHECK_INTERVAL=60

# Development/Production
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
