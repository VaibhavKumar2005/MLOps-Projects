{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Drift Alert Event",
  "description": "Data drift detection alert indicating feature distribution shift",
  "type": "object",
  "required": ["type", "symbol", "metric", "value", "z_score", "threshold", "timestamp"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["DRIFT_ALERT"],
      "description": "Event type identifier"
    },
    "symbol": {
      "type": "string",
      "description": "Stock ticker symbol where drift was detected",
      "minLength": 1,
      "maxLength": 10
    },
    "metric": {
      "type": "string",
      "enum": ["price", "return", "volatility"],
      "description": "Which metric showed drift"
    },
    "value": {
      "type": "number",
      "description": "Current metric value that triggered alert"
    },
    "z_score": {
      "type": "number",
      "description": "Standard deviations away from baseline (z-score)"
    },
    "threshold": {
      "type": "number",
      "description": "Z-score threshold that was exceeded",
      "minimum": 0
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when drift was detected"
    }
  },
  "additionalProperties": false
}
